# Required: OpenRouter API key for the AI agent (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required: Seller wallet address (Arc Testnet) for receiving x402 payments
SELLER_ADDRESS=0xYourSellerAddressHere

# Required: Seller wallet private key for withdrawals
SELLER_PRIVATE_KEY=0xYourPrivateKeyHere

# Optional: Customize the demo buyer private key (default is hardcoded for demo)
# NEXT_PUBLIC_DEMO_PRIVATE_KEY=0xYourDemoKey
